module tb_top_multifunction_reg;
    logic        clk;
    logic        btnC;
    logic [15:0] sw;
    logic [15:0] led;
    top_multifunction_reg dut (
        .clk  (clk),
        .btnC (btnC),
        .sw   (sw),
        .led  (led)
    );

    initial clk = 0;
    always #5 clk = ~clk;

    initial begin
        btnC = 1'b1;  
        sw   = '0;

        #20;
        btnC = 1'b0;   
        
        sw[2:0]  = 3'b011;  // s
        sw[3]    = 1'b0;    // shift_in
        sw[11:4] = 8'hA5;   // D
        #10;

        // hold
        sw[2:0] = 3'b000;
        #20;

        // shift left ve shift_in açık
        sw[3]   = 1'b1;
        sw[2:0] = 3'b001;
        #40;

        // shift right ve shift_in kapalı
        sw[3]   = 1'b0;
        sw[2:0] = 3'b010;
        #40;

        // rotate left
        sw[2:0] = 3'b100;
        #40;

        // rotate right
        sw[2:0] = 3'b101;
        #40;

        $stop;
    end
endmodule

module tb_multifunction_register_8;

    logic        clk;
    logic        reset;
    logic [2:0]  s;
    logic        shift_in;
    logic [7:0]  D;
    logic [7:0]  Q;

    multifunction_register_8 dut (
        .clk      (clk),
        .reset    (reset),
        .s        (s),
        .shift_in (shift_in),
        .D        (D),
        .Q        (Q)
    );

    initial clk = 0;
    always #5 clk = ~clk;

    initial begin
        reset    = 1'b1;
        s        = 3'b000;
        shift_in = 1'b0;
        D        = 8'h00;

        #20;
        reset = 1'b0;

        D = 8'hA5;
        s = 3'b011;  // load
        #10;         // one clock edge
        s = 3'b000;  // hold
        #10;

        shift_in = 1'b1;
        s = 3'b001;  // shift left
        #20;

        shift_in = 1'b0;
        s = 3'b010;  // shift right
        #20;

        // rotate left twice
        s = 3'b100;
        #20;

        // rotate right twice
        s = 3'b101;
        #20;

        // son hold
        s = 3'b000;
        #20;

        $stop;
    end
endmodule


module sevenseg_multi (
    input  logic        clk,
    input  logic        reset,   
    input  logic [15:0] w,     
    output logic        a,
    output logic        b,
    output logic        c,
    output logic        d,
    output logic        e,
    output logic        f,
    output logic        g,
    output logic [3:0]  an      
);

    logic [15:0] refresh_counter;
    logic [1:0]  digit_index;       
    logic [3:0]  current_nibble;    
    always_ff @(posedge clk) begin
        if (reset)
            refresh_counter <= '0;
        else
            refresh_counter <= refresh_counter + 1'b1;
    end

    assign digit_index = refresh_counter[15:14];

    always_comb begin
        current_nibble = 4'h0;
        an             = 4'b1111; 

        unique case (digit_index)
            2'b00: begin
                // en sag digit
                current_nibble = w[3:0];
                an             = 4'b1110; // AN0 
            end
            2'b01: begin
                current_nibble = w[7:4];
                an             = 4'b1101; // AN1 
            end
            2'b10: begin
                current_nibble = w[11:8];
                an             = 4'b1011; // AN2
            end
            2'b11: begin
                // en soldaki digit
                current_nibble = w[15:12];
                an             = 4'b0111; // AN3 
            end
        endcase
    end

    hex_to_7seg u_hex (
        .w (current_nibble),
        .a (a),
        .b (b),
        .c (c),
        .d (d),
        .e (e),
        .f (f),
        .g (g)
    );


module hex_to_7seg (
    input  logic [3:0] w,
    output logic       a,
    output logic       b,
    output logic       c,
    output logic       d,
    output logic       e,
    output logic       f,
    output logic       g
);

    logic [6:0] seg; 

    always_comb begin
        unique case (w)
            4'h0: seg = 7'b0000001; // 0
            4'h1: seg = 7'b1001111; // 1
            4'h2: seg = 7'b0010010; // 2
            4'h3: seg = 7'b0000110; // 3
            4'h4: seg = 7'b1001100; // 4
            4'h5: seg = 7'b0100100; // 5
            4'h6: seg = 7'b0100000; // 6
            4'h7: seg = 7'b0001111; // 7
            4'h8: seg = 7'b0000000; // 8
            4'h9: seg = 7'b0000100; // 9
            4'hA: seg = 7'b0001000; // A
            4'hB: seg = 7'b1100000; // b
            4'hC: seg = 7'b0110001; // C
            4'hD: seg = 7'b1000010; // d
            4'hE: seg = 7'b0110000; // E
            4'hF: seg = 7'b0111000; // F
            default: seg = 7'b1111111; // gecersiz
        endcase
    end

    assign {a,b,c,d,e,f,g} = seg;
endmodule


