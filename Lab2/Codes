module multifunction_register_8 (
    input  logic clk,
    input  logic reset, // synchronous
    input  logic [2:0]  s,
    input  logic shift_in,   // serial input
    input  logic [7:0]  D, // parallel load input
    output logic [7:0]  Q // register contents
);
    logic [7:0] d_next;
    genvar i;
    generate
        for (i = 0; i < 8; i++) begin : bit_logic
            logic [7:0] I; 

            always_comb begin

                I[0] = Q[i]; //hold

                if (i == 7) // shift left
                    I[1] = Q[6];
                else if (i > 0)
                    I[1] = Q[i-1];
                else
                    I[1] = shift_in; // i == 0

                if (i == 7) // shift right
                    I[2] = shift_in;
                else
                    I[2] = Q[i+1];

                I[3] = D[i]; // parallel load
                if (i == 0)  // rotate left
                    I[4] = Q[7];
                else
                    I[4] = Q[i-1];

                if (i == 7) // rotate right
                    I[5] = Q[0]; 
                else
                    I[5] = Q[i+1];

                I[6] = 1'b0;// kullanılmıyo
                I[7] = 1'b0;// kullanılmıyo
            end

            // her bite 1 mux 
            mux8_1 u_mux (
                .I   (I),
                .sel (s),
                .y   (d_next[i])
            );
  dff_sync_reset dff_i (
            .clk   (clk),
            .reset (reset),
            .d     (d_next[i]),
            .q     (Q[i])
        );
        end
    endgenerate
endmodule

module mux8_1 (
    input  logic [7:0] I,
    input  logic [2:0] sel,
    output logic       y
);
    always_comb begin
        unique case (sel)
            3'b000: y = I[0]; //hold
            3'b001: y = I[1]; //shift left
            3'b010: y = I[2]; //shift right
            3'b011: y = I[3]; //load
            3'b100: y = I[4]; //rotate left
            3'b101: y = I[5]; //rotate right
            default: y = 1'b0; // I6 ve I7 kullanılmıyo (0)
        endcase
    end
endmodule


module dff_sync_reset #(
    parameter WIDTH = 1
)(
    input  logic clk,
    input  logic reset, 
    input  logic [WIDTH-1:0] d,
    output logic [WIDTH-1:0] q
);
    always_ff @(posedge clk) begin
        if (reset)
            q <= '0;
        else
            q <= d;
    end
endmodule

