module lab3_top (
    input  logic        clk,    
    input  logic [15:0] sw,
    output logic [15:0] led,
    output logic [6:0]  seg,
    output logic [3:0]  an
);

    logic        reset_sw;
    logic [2:0]  s;
    logic [11:0] load_value;

    assign s          = sw[15:13];
    assign reset_sw   = sw[12];
    assign load_value = sw[11:0];

    logic clk_2Hz;
    logic clk_1kHz;

  clock_divider u_clk_div (
    .clk      (clk),
    .clk_2Hz  (clk_2Hz),
    .clk_1kHz (clk_1kHz)
);

    logic [15:0] count;

    lab_counter_16 u_lab_counter_16 (
        .clk        (clk_2Hz),     
        .reset      (reset_sw),
        .s          (s),
        .load_value (load_value),
        .count      (count)
    );

    sevenseg_driver_4digit u_sevenseg_driver (
        .clk   (clk_1kHz),        
        .reset (reset_sw),
        .value (count),
        .seg   (seg),
        .an    (an)
    );
    
    localparam logic [15:0] ALARM_VALUE = 16'h0BE6;

    logic alarm_active;
    logic alarm_flash;

    assign alarm_active = (count >= ALARM_VALUE);

    always_ff @(posedge clk_2Hz) begin
        if (reset_sw)
            alarm_flash <= 1'b0;
        else if (alarm_active)
            alarm_flash <= ~alarm_flash;
        else
            alarm_flash <= 1'b0;
    end

    always_comb begin
        led[7:0]  = count[7:0]; 
        if (alarm_active)
            led[15:8] = {8{alarm_flash}};
        else
            led[15:8] = count[15:8];     
    end
endmodule

module clock_divider (
    input  logic clk,   
    input  logic reset,
    output logic clk_2Hz,
    output logic clk_1kHz
);
    localparam int N_2HZ  = 25_000_000;
    localparam int N_1KHZ = 50_000;

    logic [25:0] cnt_2Hz;     
    logic [15:0] cnt_1kHz;   

    always_ff @(posedge clk) begin
        if (reset) begin
            cnt_2Hz  <= '0;
            clk_2Hz  <= 1'b0;
        end
        else begin
            if (cnt_2Hz == N_2HZ-1) begin
                cnt_2Hz <= '0;
                clk_2Hz <= ~clk_2Hz;
            end
            else begin
                cnt_2Hz <= cnt_2Hz + 1'b1;
            end
        end
    end

    always_ff @(posedge clk) begin
        if (reset) begin
            cnt_1kHz  <= '0;
            clk_1kHz  <= 1'b0;
        end
        else begin
            if (cnt_1kHz == N_1KHZ-1) begin
                cnt_1kHz <= '0;
                clk_1kHz <= ~clk_1kHz;
            end
            else begin
                cnt_1kHz <= cnt_1kHz + 1'b1;
            end
        end
    end
endmodule

module multifunction_register_8 (
    input  logic        clk,
    input  logic        reset,      // synchronous
    input  logic [2:0]  s,
    input  logic        shift_in,   // serial input
    input  logic [7:0]  D,          // parallel load input
    output logic [7:0]  Q           // register contents
);
    logic [7:0] d_next;

    genvar i;
    generate
        for (i = 0; i < 8; i++) begin : bit_logic
            logic [7:0] I; 
            always_comb begin
                // I[0] = hold (keep same bit)
                I[0] = Q[i];

                // shift left
                if (i == 7)
                    I[1] = Q[6];
                else if (i > 0)
                    I[1] = Q[i-1];
                else
                    I[1] = shift_in; // i == 0

                // shift right
                if (i == 7)
                    I[2] = shift_in;
                else
                    I[2] = Q[i+1];

                // parallel load
                I[3] = D[i];

                // rotate left
                if (i == 0)
                    I[4] = Q[7];
                else
                    I[4] = Q[i-1];

                // rotate right
                if (i == 7)
                    I[5] = Q[0];
                else
                    I[5] = Q[i+1];

                // unused
                I[6] = 1'b0;
                I[7] = 1'b0;
            end

            // one mux per bit
            mux8_1 u_mux (
                .I   (I),
                .sel (s),
                .y   (d_next[i])
            );

            dff_sync_reset dff_i (
                .clk   (clk),
                .reset (reset),
                .d     (d_next[i]),
                .q     (Q[i])
            );
        end
    endgenerate
endmodule

module lab_counter_16 (
    input  logic        clk,         
    input  logic        reset,
    input  logic [2:0]  s,           
    input  logic [11:0] load_value,  
    output logic [15:0] count        
);
    logic [7:0] Q_low,  Q_high;
    logic [7:0] D_low,  D_high;
    logic       shift_in_low;
    logic       shift_in_high;

    assign D_low  = load_value[7:0];
    assign D_high = {4'b0000, load_value[11:8]};

    always_comb begin

        shift_in_low  = 1'b0;
        shift_in_high = 1'b0;

        unique case (s)
            3'b001: begin // shift left
                shift_in_low  = 1'b0;   
                shift_in_high = Q_low[7];  
            end
            3'b010: begin // shift right
                shift_in_low  = Q_high[0]; 
                shift_in_high = 1'b0;     
            end
            default: begin
                // hold, parallel load, rotate
                shift_in_low  = 1'b0;
                shift_in_high = 1'b0;
            end
        endcase
    end

    multifunction_register_8 reg_low (
        .clk      (clk),
        .reset    (reset),
        .s        (s),
        .shift_in (shift_in_low),
        .D        (D_low),
        .Q        (Q_low)
    );

    multifunction_register_8 reg_high (
        .clk      (clk),
        .reset    (reset),
        .s        (s),
        .shift_in (shift_in_high),
        .D        (D_high),
        .Q        (Q_high)
    );

    assign count = {Q_high, Q_low};
endmodule

module hex_to_7seg (
    input  logic [3:0] w,
    output logic       a,
    output logic       b,
    output logic       c,
    output logic       d,
    output logic       e,
    output logic       f,
    output logic       g
);
    // {a,b,c,d,e,f,g}
    logic [6:0] seg;

    always_comb begin
        unique case (w)
            4'h0: seg = 7'b0000001; // 0
            4'h1: seg = 7'b1001111; // 1
            4'h2: seg = 7'b0010010; // 2
            4'h3: seg = 7'b0000110; // 3
            4'h4: seg = 7'b1001100; // 4
            4'h5: seg = 7'b0100100; // 5
            4'h6: seg = 7'b0100000; // 6
            4'h7: seg = 7'b0001111; // 7
            4'h8: seg = 7'b0000000; // 8
            4'h9: seg = 7'b0000100; // 9
            4'hA: seg = 7'b0001000; // A
            4'hB: seg = 7'b1100000; // b
            4'hC: seg = 7'b0110001; // C
            4'hD: seg = 7'b1000010; // d
            4'hE: seg = 7'b0110000; // E
            4'hF: seg = 7'b0111000; // F
            default: seg = 7'b1111111; // all off (invalid)
        endcase
    end

    assign {a,b,c,d,e,f,g} = seg;


module mux8_1 (
    input  logic [7:0] I,
    input  logic [2:0] sel,
    output logic       y
);
    always_comb begin
        unique case (sel)
            3'b000: y = I[0]; // hold
            3'b001: y = I[1]; // shift left
            3'b010: y = I[2]; // shift right
            3'b011: y = I[3]; // parallel load
            3'b100: y = I[4]; // rotate left
            3'b101: y = I[5]; // rotate right
            default: y = 1'b0; // I6 and I7 unused (0)
        endcase
    end
endmodule


module dff_sync_reset #(
    parameter WIDTH = 1
)(
    input  logic                 clk,
    input  logic                 reset, 
    input  logic [WIDTH-1:0]     d,
    output logic [WIDTH-1:0]     q
);
    always_ff @(posedge clk) begin
        if (reset)
            q <= '0;
        else
            q <= d;
    end
endmodule

module tb_lab_counter_16;
    logic        clk;
    logic        reset;
    logic [2:0]  s;
    logic [11:0] load_value;
    logic [15:0] count;

    lab_counter_16 dut (
        .clk        (clk),
        .reset      (reset),
        .s          (s),
        .load_value (load_value),
        .count      (count)
    );

    initial clk = 1'b0;
    always #5 clk = ~clk;

    initial begin

        reset      = 1'b1;
        s          = 3'b000;      // hold
        load_value = 12'h014;     

        #20;
        reset = 1'b0;

        s = 3'b011;
        #10;

        // hold
        s = 3'b000;
        #20;

        // bikaç kere double (shift left)
        s = 3'b001; 
        #100;

        // bikaç kere half (shift right)
        s = 3'b010;
        #100;

        $stop;
    end
endmodule

